class FakeQuerySetIterable:
    queryset: FakeQuerySet
    def __init__(self, queryset: FakeQuerySet) -> None: ...

class ModelIterable(FakeQuerySetIterable):
    def __iter__(self) -> Iterator[Model]: ...

class DictIterable(FakeQuerySetIterable):
    def __iter__(self) -> Iterator[dict[str, Any]]: ...

class ValuesListIterable(FakeQuerySetIterable):
    def __iter__(self) -> Iterator[tuple[Any, ...]]: ...

class FlatValuesListIterable(FakeQuerySetIterable):
    def __iter__(self) -> Iterator[Any]: ...

class FakeQuerySet:
    model: type[Model]
    results: list[Model]
    dict_fields: Sequence[str]
    tuple_fields: Sequence[str]
    iterable_class: type[FakeQuerySetIterable]
    ordered: bool
    def __init__(self, model: type[Model], results: list[Model]) -> None: ...
    def all(self) -> Self: ...
    def get_clone(self, results: list[Model] | None = None) -> FakeQuerySet: ...
    def resolve_q_object(self, q_object: Q) -> Callable[[Model], bool]: ...
    def filter(self, *args: Q, **kwargs: Any) -> FakeQuerySet: ...
    def exclude(self, *args: Q, **kwargs: Any) -> FakeQuerySet: ...
    def get(self, *args: Q, **kwargs: Any) -> Model: ...
    def count(self) -> int: ...
    def exists(self) -> bool: ...
    def first(self) -> Model | None: ...
    def last(self) -> Model | None: ...
    def select_related(self, *args: str) -> Self: ...
    def prefetch_related(self, *args: str | Prefetch[Any, Any, Any]) -> Self: ...
    def only(self, *args: str) -> Self: ...
    def defer(self, *args: str) -> Self: ...
    def values(self, *fields: str) -> FakeQuerySet: ...
    def values_list(self, *fields: str, flat: bool | None = None) -> FakeQuerySet: ...
    def order_by(self, *fields: str) -> FakeQuerySet: ...
    def distinct(self, *fields: str) -> FakeQuerySet: ...
    @property
    def _result_cache(self) -> list[Model]: ...
    @_result_cache.setter
    def _result_cache(self, val: Iterable[Model]) -> None: ...
    @overload
    def __getitem__(self, k: int) -> Model: ...
    @overload
    def __getitem__(self, k: slice) -> list[Model]: ...
    def __iter__(self) -> Iterator[Any]: ...
    def __nonzero__(self) -> bool: ...
    def __len__(self) -> int: ...
    def __repr__(self) -> str: ...
